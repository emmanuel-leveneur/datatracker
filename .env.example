# Copier ce fichier en .env et adapter les valeurs

# Base de données
# SQLite (défaut, chemin absolu recommandé) :
# DATABASE_URL=sqlite:////home/user/datatracker.db
#
# PostgreSQL :
# DATABASE_URL=postgresql://user:password@localhost:5432/datatracker

# Clé secrète pour les sessions (générer avec : python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production-use-env-var

# URL publique de l'application (utilisée dans les liens des emails)
# APP_URL=https://datatracker.example.com

# SMTP — envoi d'emails pour les alertes de type "Email" (optionnel)
# Si SMTP_HOST est vide, les notifications email sont désactivées silencieusement.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true
